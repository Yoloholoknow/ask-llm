# ask-llm environment configuration
# Copy this to .env and adjust to your setup:
#   cp .env.example .env

# ── Model selection ────────────────────────────────────────────────────────────
# Choose based on your hardware. Rule of thumb:
#   model RAM usage ≈ (params × 0.5) for Q4 quantization
#   leave at least 1 GB free for the OS
#
# ┌─────────────────────┬────────────┬───────────┬────────────────────────────┐
# │ Model               │ RAM needed │ Speed     │ Best for                   │
# ├─────────────────────┼────────────┼───────────┼────────────────────────────┤
# │ qwen2.5:0.5b        │ ~0.5 GB    │ very fast │ Weak hardware, simple Q&A  │
# │ qwen2.5:1.5b        │ ~1.1 GB    │ fast      │ Pi 4 / 4 GB RAM (default)  │
# │ qwen2.5:3b          │ ~2.0 GB    │ moderate  │ Pi 4 / 8 GB, decent laptop │
# │ qwen2.5:7b          │ ~4.5 GB    │ slow*     │ 8+ GB RAM, has GPU         │
# │ qwen2.5-coder:1.5b  │ ~1.1 GB    │ fast      │ Code-only tasks            │
# │ qwen2.5-coder:7b    │ ~4.5 GB    │ slow*     │ Serious coding, 8+ GB      │
# │ phi3:mini           │ ~2.3 GB    │ moderate  │ Alternative to qwen 1.5b   │
# │ gemma2:2b           │ ~1.7 GB    │ moderate  │ Alternative mid-tier       │
# └─────────────────────┴────────────┴───────────┴────────────────────────────┘
# * "slow" on CPU-only. Fast if you have a GPU.
#
# GPU users: Ollama auto-detects CUDA/Metal. Just pick a larger model.
# To see all available models: https://ollama.com/library

ASK_MODEL=qwen2.5:1.5b

# ── Server binding ─────────────────────────────────────────────────────────────
# LOCAL: bind to 127.0.0.1 so Ollama is not exposed on the network
# SERVER (Pi/cloud): bind to 0.0.0.0 so it's reachable over Tailscale/LAN
# Default here is local-safe (127.0.0.1)

OLLAMA_BIND=127.0.0.1
