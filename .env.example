# ask-llm environment configuration
# Copy this to .env and adjust to your setup:
#   cp .env.example .env

# ── Model selection ────────────────────────────────────────────────────────────
# Pick based on hardware. Rule of thumb: leave at least 1 GB free for the OS.
# Runtime RAM ≈ download size × 1.3 (KV cache + overhead on top of weights).
#
# Pi 4 (4 GB) CPU inference reality: peak is ~3–8 tok/s for 1B models.
# Bottleneck is ARM memory bandwidth, not storage. Swapping SD → SSD only
# reduces cold-start load time, not sustained generation speed.
#
# ┌──────────────────────────┬─────────────┬──────────┬──────────┬────────────────┬──────────────────────────────────────────┐
# │ Model                    │ Family/gen  │ Download │ Runtime  │ Pi 4 tok/s     │ Best for                                 │
# ├──────────────────────────┼─────────────┼──────────┼──────────┼────────────────┼──────────────────────────────────────────┤
# │ gemma3:1b             ★  │ Gemma 3     │  815 MB  │ ~1.2 GB  │ ~4–6 tok/s     │ Pi 4 — best quality/speed balance at 1B  │
# │ qwen3.5:0.8b             │ Qwen 3.5 ✦ │  1.0 GB  │ ~1.4 GB  │ ~3–4 tok/s     │ Pi 4 alternative; supports thinking mode │
# │ llama3.2:1b              │ Llama 3.2   │  630 MB  │ ~0.9 GB  │ ~4–6 tok/s     │ Pi 4 — strong instruction following      │
# │ qwen3.5:2b-q4_K_M        │ Qwen 3.5 ✦ │  1.9 GB  │ ~2.6 GB  │ ~1–2 tok/s     │ 4 GB quality lean / 6 GB+               │
# │ llama3.2:3b              │ Llama 3.2   │  2.0 GB  │ ~2.7 GB  │ <1 tok/s       │ General knowledge, laptop / 8 GB Pi     │
# │ granite4.1:3b            │ Granite 4.1 │  2.1 GB  │ ~2.8 GB  │ <1 tok/s       │ Tools / RAG / code, non-Qwen            │
# │ qwen3.5:4b               │ Qwen 3.5 ✦ │  3.4 GB  │ ~4.0 GB  │ too slow on Pi │ 6 GB+ free RAM                          │
# │ qwen3.5:9b               │ Qwen 3.5 ✦ │  6.6 GB  │ ~8.0 GB  │ —              │ 8 GB+ / GPU — best quality               │
# └──────────────────────────┴─────────────┴──────────┴──────────┴────────────────┴──────────────────────────────────────────┘
# ★ gemma3:1b recommended for Pi 4: designed for on-device inference, better
#   instruction following than qwen3.5:0.8b at similar or faster speed.
#   Pull with: ollama pull gemma3:1b
#
# ✦ Qwen 3.5 models support thinking mode (reasoning trace). The client disables it by
#   default (ASK_THINK=false) for snappy answers. See ASK_THINK below to re-enable.
#
# ⚠  Use qwen3.5:2b-q4_K_M (not plain qwen3.5:2b) on 4 GB — the default :2b tag is
#    2.7 GB (Q8) and leaves too little headroom.
#
# Full model library: https://ollama.com/library

ASK_MODEL=qwen3.5:0.8b

# ── Server binding ─────────────────────────────────────────────────────────────
# LOCAL: bind to 127.0.0.1 so Ollama is not exposed on the network
# SERVER (Pi/cloud): bind to 0.0.0.0 so it's reachable over Tailscale/LAN
# Default here is local-safe (127.0.0.1)

OLLAMA_BIND=127.0.0.1

# ── Throughput ────────────────────────────────────────────────────────────────
# These are set in docker-compose.yml by default; override here if needed.
#
# Flash attention — faster inference and lower KV-cache memory (CPU + GPU).
# Set to 0 to disable if you see instability.
OLLAMA_FLASH_ATTENTION=1
#
# Quantized KV cache — halves context memory cost; requires flash attention.
# q8_0 is a good balance; q4_0 saves more but may reduce quality slightly.
OLLAMA_KV_CACHE_TYPE=q8_0
#
# Container memory cap — prevents OOM-killing your Pi under load.
# Raise for larger models; lowering too much kills the model mid-response.
# Suggested: 2000m (0.8b), 3500m (2-3b), 5000m (4b).
OLLAMA_MEM_LIMIT=3500m
#
# Keep-alive — how long Ollama keeps a model loaded in RAM between requests.
#   -1  = forever (lowest reload latency; fine when RAM is plentiful)
#    0  = unload immediately after each response
#   5m  = unload after 5 min idle (recommended on RAM-constrained hosts like Pi)
# The default (5m) reclaims ~1–3.5 GB after an idle period, preventing
# memory exhaustion on 4 GB boards that also run other services.
OLLAMA_KEEP_ALIVE=5m

# ── Context window ────────────────────────────────────────────────────────────
# num_ctx controls how many tokens the model can hold in its context window.
# Smaller = less memory bandwidth per token = faster generation on CPU hardware.
# Default 1024 is enough for all ask/fix queries and roughly halves bandwidth
# vs Ollama's default of 2048.
# Raise to 2048+ only if you need very long responses or large error dumps.
ASK_NUM_CTX=1024

# ── CPU threads ───────────────────────────────────────────────────────────────
# Ollama defaults to all available CPU cores. On a dedicated inference box,
# leave this unset. On a shared Pi running other services, capping at 3 leaves
# one core free for the OS and other tasks. Inference is bursty (~3–8s per
# query), so the scheduler handles contention fine in most cases.
# Uncomment to cap:
# OLLAMA_NUM_THREADS=3

# ── Think mode ────────────────────────────────────────────────────────────────
# Qwen 3.5 (and other reasoning models) emit a reasoning trace before answering.
# The client sends "think: false" by default — fast, clean output.
# Set to true to enable the full reasoning trace (slower, more tokens).
ASK_THINK=false
